# Copy to .env.local for dev, or set in Railway → Variables for prod.
# Augen falls back to deterministic mocks for anything without a key.

# ─── AI providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=
# Hard cap on real Claude spending (display + auto-fallback to mock past this).
ANTHROPIC_BUDGET_USD=

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Comma-separated fallback chain — tries each in order until one returns 200.
GEMINI_IMAGE_MODEL_CHAIN=gemini-3.1-flash-image-preview,gemini-3-pro-image-preview,nano-banana-pro-preview,gemini-2.5-flash-image,imagen-4.0-fast-generate-001,imagen-4.0-generate-001

PEXELS_API_KEY=

FIGMA_PERSONAL_ACCESS_TOKEN=

# ─── Auth (closed beta) ─────────────────────────────────────────────────────
# Comma-separated list of allowed email addresses. Empty = open sign-up.
AUGEN_ALLOWED_EMAILS=

# ─── Credits & tiers ────────────────────────────────────────────────────────
# Override the default credit grants per tier if you want.
AUGEN_TIER_TRIAL_CREDITS=50
AUGEN_TIER_STUDIO_CREDITS=500
AUGEN_TIER_PRO_CREDITS=2000
AUGEN_TIER_ENTERPRISE_CREDITS=20000

# Override per-action credit prices (1 credit ≈ $0.02 retail).
AUGEN_PRICE_AD_CLAUDE=5
AUGEN_PRICE_AD_IMAGE=5
AUGEN_PRICE_STRATEGIST=3
AUGEN_PRICE_SPIN_VARIANTS=2
AUGEN_PRICE_RULE_REFINER=3
AUGEN_PRICE_TOKEN_EXTRACT=5
AUGEN_PRICE_STOCK_SEARCH=1
AUGEN_PRICE_IMAGE_GENERATE=8
AUGEN_PRICE_CRITIC_PREVIEW=1

# Override Claude pricing if rates change ($ / million tokens).
ANTHROPIC_PRICE_IN_PER_MTOK=3.0
ANTHROPIC_PRICE_OUT_PER_MTOK=15.0
ANTHROPIC_PRICE_CACHE_WRITE_PER_MTOK=3.75
ANTHROPIC_PRICE_CACHE_READ_PER_MTOK=0.30

# ─── Observability ──────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
