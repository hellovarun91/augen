# Drop this file as .env.local and fill what you have.
# Augen falls back to deterministic mocks for anything without a key.

# Claude — Strategist, Copywriter, QC Critic, token extraction from artwork
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: override max output tokens per call (default 4096)
ANTHROPIC_MAX_TOKENS=

# Gemini Nano Banana 2 — real photographic backgrounds
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Pexels — free stock photos
PEXELS_API_KEY=

# Figma — two-way Variables sync
FIGMA_PERSONAL_ACCESS_TOKEN=
